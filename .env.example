# =============================================================
# tubemind-secure-mcp — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================

# -------------------------------------------------------------
# YouTube OAuth2
# Crie em: https://console.cloud.google.com/apis/credentials
# -------------------------------------------------------------
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:4000/oauth/callback

# -------------------------------------------------------------
# Segurança — Token Encryption
# Gere com: openssl rand -hex 32
# -------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# -------------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT_MS=10000

# -------------------------------------------------------------
# Audit Log
# -------------------------------------------------------------
AUDIT_LOG_PATH=./logs/audit.log

# -------------------------------------------------------------
# Ambiente
# -------------------------------------------------------------
NODE_ENV=development
