{
  "name": "tubemind-secure-mcp",
  "version": "0.1.0",
  "description": "YouTube intelligence, powered by Claude. Secure by design.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tubemind-secure-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:security": "pnpm audit --audit-level=high",
    "auth": "tsx --env-file=.env src/auth-server.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.10.2",
    "googleapis": "144.0.0",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@types/node": "22.10.0",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.2",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.16.0",
    "tsx": "4.19.4",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
